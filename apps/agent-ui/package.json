{
  "name": "agent-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun --bun vite build",
    "check-types": "tsc --noEmit",
    "dev": "bun --bun vite dev --port 3008",
    "fmt": "bun run fix",
    "lint": "biome lint .",
    "start": "bun --bun vite preview --port 3008",
    "deploy": "bun run build && bunx wrangler pages deploy dist/client --project-name=duyet-agents",
    "cf:deploy": "bun run --env-file=../../.env.production --env-file=../../.env.production.local build && bunx wrangler pages deploy dist/client --project-name=duyet-agents --commit-dirty=true",
    "cf:deploy:prod": "../../scripts/cf-deploy-prod.sh agent-ui duyet-agents"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.118",
    "@clerk/clerk-react": "^5.61.2",
    "ai": "^6.0.180",
    "lucide-react": "^1.0.0",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@duyet/tsconfig": "*",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.0",
    "vite": "^8.0.0"
  }
}
