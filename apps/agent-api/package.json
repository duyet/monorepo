{
  "name": "agent-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "config": "tsx ../../scripts/sync-app-secrets.ts duyet-agent-api",
    "dev": "pnpm dlx wrangler dev --env development --config wrangler.toml --port 8788",
    "deploy": "pnpm run check-types && pnpm dlx wrangler deploy --env=\"\" --config wrangler.toml",
    "cf:deploy:prod": "dotenv -e ../../.env.production -e ../../.env.production.local -- pnpm run deploy",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome lint .",
    "fmt": "biome format --write ."
  },
  "dependencies": {
    "@clerk/backend": "^2.32.0",
    "@cloudflare/ai-chat": "^0.9.0",
    "agents": "^0.17.0",
    "ai": "^7.0.4",
    "workers-ai-provider": "^3.1.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@duyet/tsconfig": "*",
    "@types/node": "^25.7.0",
    "typescript": "^6.0.3"
  }
}
