{
  "name": "home",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "config": "tsx ../../scripts/sync-app-secrets.ts duyet-home",
    "prebuild": "cd ../blog && tsx scripts/generate-posts-data.ts",
    "build": "vite build && tsx ../../scripts/patch-html-for-cloudflare.ts",
    "check-types": "tsc --noEmit",
    "dev": "vite dev --port 3001",
    "fmt": "pnpm run fix",
    "lint": "biome lint .",
    "deploy": "pnpm run build && pnpm dlx wrangler pages deploy dist/client --project-name=duyet-home",
    "cf:deploy": "dotenv -e ../../.env.production -e ../../.env.production.local -- pnpm run build && pnpm dlx wrangler pages deploy dist/client --project-name=duyet-home --commit-dirty=true",
    "cf:deploy:prod": "../../scripts/cf-deploy-prod.sh home duyet-home"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.2",
    "@cloudflare/ai-search-snippet": "^0.0.40",
    "@duyet/components": "*",
    "@duyet/libs": "*",
    "@duyet/urls": "*",
    "@phosphor-icons/react": "^2.1.10",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tanstack/react-router": "^1.0.0",
    "@tanstack/react-start": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.36.0",
    "lucide-react": "^1.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^3.4.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@duyet/tailwind-config": "*",
    "@duyet/tsconfig": "*",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^6.0.0"
  }
}
