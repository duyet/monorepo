{
  "name": "llm-timeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "bun test",
    "config": "bun ../../scripts/sync-app-secrets.ts duyet-llm-timeline",
    "build": "bun run prebuild && bun --bun vite build",
    "check-types": "tsc --noEmit",
    "dev": "bun --bun vite dev --port 3005",
    "fmt": "bun run fix",
    "lint": "biome lint .",
    "start": "bun --bun vite preview --port 3005",
    "deploy": "bun run build && bunx wrangler pages deploy dist/client --project-name=duyet-llm-timeline",
    "cf:deploy": "bun run --env-file=../../.env.production --env-file=../../.env.production.local build && bunx wrangler pages deploy dist/client --project-name=duyet-llm-timeline --commit-dirty=true",
    "cf:deploy:prod": "../../scripts/cf-deploy-prod.sh llm-timeline duyet-llm-timeline",
    "rss": "bun scripts/generate-rss.ts",
    "llms-txt": "bun scripts/generate-llms-txt.ts",
    "sitemap": "bun scripts/generate-sitemap.ts",
    "prebuild": "bun scripts/generate-rss.ts && bun scripts/generate-llms-txt.ts && bun scripts/generate-data-json.ts",
    "sync": "bun scripts/sync-data.ts",
    "sync:dry": "bun scripts/sync-data.ts --dry-run --verbose"
  },
  "dependencies": {
    "@duyet/components": "*",
    "@duyet/libs": "*",
    "@duyet/urls": "*",
    "@duyet/wasm": "*",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-router": "^1.0.0",
    "@tanstack/react-start": "^1.0.0",
    "@tanstack/react-virtual": "^3.13.22",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^1.0.0",
    "next-themes": "^0.4.6",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@duyet/tailwind-config": "*",
    "@duyet/tsconfig": "*",
    "@tailwindcss/vite": "^4.0.0",
    "@happy-dom/global-registrator": "^20.8.4",
    "@types/react": "^19.2.14",
    "happy-dom": "^20.8.4",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^6.0.0"
  }
}
