{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Agents App",
  "extends": "@duyet/tsconfig/vite.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "allowJs": true,
    "declaration": false,
    "declarationMap": false,
    "resolveJsonModule": true,
    "strict": true,
    "strictNullChecks": true,
    "downlevelIteration": true,
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "src",
    "app",
    "artifacts",
    "components",
    "lib",
    "hooks",
    "types.d.ts",
    "vendor.d.ts",
    "vite.config.ts"
  ],
  "exclude": [
    "node_modules",
    "functions",
    "**/*.test.ts",
    "**/*.test.tsx",
    "out",
    ".next"
  ]
}
