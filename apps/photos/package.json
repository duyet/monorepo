{
  "name": "photos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "config": "tsx ../../scripts/sync-app-secrets.ts duyet-photos",
    "prebuild": "tsx scripts/generate-photos-data.ts",
    "build": "vite build && tsx ../../scripts/patch-html-for-cloudflare.ts",
    "dev": "vite dev --port 3003",
    "fmt": "pnpm run fix",
    "lint": "biome lint .",
    "start": "vite preview --port 3003",
    "check-types": "tsc --noEmit",
    "deploy": "pnpm run build && pnpm dlx wrangler pages deploy dist/client --project-name=duyet-photos",
    "cf:deploy": "dotenv -e ../../.env.production -e ../../.env.production.local -- pnpm run build && pnpm dlx wrangler pages deploy dist/client --project-name=duyet-photos --commit-dirty=true",
    "cf:deploy:prod": "../../scripts/cf-deploy-prod.sh photos duyet-photos",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clickhouse/client": "^1.12.1",
    "@duckdb/node-api": "^1.5.2-r.1",
    "@duyet/components": "*",
    "@duyet/libs": "*",
    "@duyet/wasm": "*",
    "@radix-ui/react-dialog": "^1.1.2",
    "@tanstack/react-router": "^1.0.0",
    "@tanstack/react-start": "^1.0.0",
    "cloudinary": "^2.5.1",
    "lucide-react": "^1.0.0",
    "next-themes": "^0.4.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-masonry-css": "^1.0.16",
    "unsplash-js": "^7.0.15"
  },
  "devDependencies": {
    "@duyet/tailwind-config": "*",
    "@duyet/tsconfig": "*",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.4",
    "typescript": "*",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^6.0.0"
  }
}
