{
  "extends": "@duyet/tsconfig/vite.json",
  "compilerOptions": {
    "strictNullChecks": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "scripts/**/*.ts",
    "types.d.ts",
    "app/rss.xml/__tests__/**/*.ts",
    "app/robots.txt/__tests__/**/*.ts"
  ],
  "exclude": ["node_modules", ".output"]
}
