{
  "name": "agent-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check-types": "tsc --noEmit",
    "dev": "vite dev --port 3008",
    "fmt": "pnpm run fix",
    "lint": "biome lint .",
    "start": "vite preview --port 3008",
    "deploy": "pnpm run build && pnpm dlx wrangler pages deploy dist/client --project-name=duyet-agents",
    "cf:deploy": "dotenv -e ../../.env.production -e ../../.env.production.local -- pnpm run build && pnpm dlx wrangler pages deploy dist/client --project-name=duyet-agents --commit-dirty=true",
    "cf:deploy:prod": "tsx ../../scripts/cf-deploy-prod.ts agent-ui duyet-agents"
  },
  "dependencies": {
    "@ai-sdk/react": "^4.0.5",
    "@clerk/clerk-react": "^5.61.2",
    "@duyet/components": "*",
    "@duyet/libs": "*",
    "@radix-ui/react-collapsible": "^1.1.14",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-hover-card": "^1.1.17",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@radix-ui/react-use-controllable-state": "^1.2.3",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "ai": "^7.0.4",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.0.0",
    "motion": "^12.42.0",
    "nanoid": "^5.1.16",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "streamdown": "^2.5.0",
    "use-stick-to-bottom": "^1.1.6"
  },
  "devDependencies": {
    "@duyet/tsconfig": "*",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.0",
    "vite": "^8.0.0"
  }
}
