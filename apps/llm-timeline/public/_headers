# Cloudflare Pages headers for the LLM release timeline (all responses are
# public, read-only, non-user-specific). Explicit `Cache-Control: public` lets
# the Workers/edge tiered cache store them; a deploy purges the Pages cache so
# content is never stale after a publish.

# SPA shell + filter pages: fresh briefly, served stale while revalidating.
# Nested RSS feeds (/license/*/rss.xml, /org/*/rss.xml, /year/*/rss.xml)
# inherit this policy.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Cache-Control: public, max-age=300, stale-while-revalidate=86400

# Hashed JS/CSS: filename carries a content hash -> cache forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Generated model dataset (regenerated each build) — large, stable per deploy
/data.json
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Main feeds + SEO endpoints (regenerated each build)
/rss.xml
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/sitemap.xml
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/llms.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/favicon.svg
  Cache-Control: public, max-age=604800
