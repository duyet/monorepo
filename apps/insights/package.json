{
  "name": "insights",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "browser": {
    "fs": false,
    "os": false,
    "path": false
  },
  "scripts": {
    "config": "tsx ../../scripts/sync-app-secrets.ts duyet-insights",
    "sync:cache": "dotenv -e .env.local -- tsx scripts/sync-analytics-cache.ts",
    "sync:motherduck": "dotenv -e .env.local -- tsx scripts/sync-to-motherduck.ts",
    "prebuild": "cd ../blog && tsx scripts/generate-posts-data.ts",
    "build": "vite build && tsx ../../scripts/patch-html-for-cloudflare.ts",
    "check-types": "tsc --noEmit",
    "dev": "vite dev --port 3001",
    "fmt": "pnpm run fix",
    "lint": "biome lint .",
    "start": "vite preview --port 3001",
    "deploy": "pnpm run build && pnpm dlx wrangler pages deploy dist/client --project-name=duyet-insights",
    "cf:deploy": "dotenv -e ../../.env.production -e ../../.env.production.local -- pnpm run build && pnpm dlx wrangler pages deploy dist/client --project-name=duyet-insights --commit-dirty=true",
    "cf:deploy:prod": "../../scripts/cf-deploy-prod.sh insights duyet-insights",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@clickhouse/client": "^1.12.1",
    "@duckdb/node-api": "^1.5.2-r.1",
    "@duyet/components": "*",
    "@duyet/config": "*",
    "@duyet/libs": "*",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-progress": "^1.1.7",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-router": "^1.122.0",
    "@tanstack/react-start": "^1.0.0",
    "clsx": "^2.1.1",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "graphql-request": "^6.1.0",
    "lucide-react": "^1.0.0",
    "motion": "^11.18.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-is": "^19.1.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^2.6.0",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^6.0.0"
  },
  "devDependencies": {
    "@duyet/interfaces": "*",
    "@duyet/tailwind-config": "*",
    "@duyet/tsconfig": "*",
    "@types/d3-scale": "^4.0.8",
    "@types/d3-shape": "^3.1.6",
    "@types/react": "^19.1.4",
    "typescript": "*"
  }
}
