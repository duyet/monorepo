{
  "extends": "@duyet/tsconfig/vite.json",
  "compilerOptions": {
    "strictNullChecks": true,
    "allowJs": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "vite.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "config/**/*.ts",
    "config/**/*.tsx",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": ["node_modules", "**/__tests__", ".output", "dist"]
}
