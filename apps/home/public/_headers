# Cloudflare Pages Headers
# https://developers.cloudflare.com/pages/configuration/headers/

# Root and HTML files - cache but revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff

# Static assets - long cache
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Images - long cache
/screenshots/*
  Cache-Control: public, max-age=31536000, immutable

# Ensure llms.txt is served as plain text and not redirected
/llms.txt
  Content-Type: text/plain; charset=utf-8
  X-Content-Type-Options: nosniff

# Security headers
/*
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Content-Type-Options: nosniff
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com https://clerk.duyet.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://cloudflareinsights.com https://*.search.ai.cloudflare.com https://84249c5c-c9b2-418d-8f03-ab3335997606.search.ai.cloudflare.com https://clerk.duyet.net https://api.clerk.com https://*.clerk.accounts.dev; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
