{
  "name": "homelab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "config": "bun ../../scripts/sync-app-secrets.ts duyet-homelab",
    "build": "bun --bun next build",
    "check-types": "tsc --noEmit",
    "dev": "bun --bun next dev --turbopack -p 3002",
    "fmt": "bun run fix",
    "lint": "biome lint .",
    "start": "bun --bun next start",
    "test": "bun test",
    "deploy": "bun run build && bunx wrangler pages deploy out --project-name=duyet-homelab",
    "cf:deploy": "bun run --env-file=../../.env.production --env-file=../../.env.production.local build && bunx wrangler pages deploy out --project-name=duyet-homelab --commit-dirty=true",
    "cf:deploy:prod": "../../scripts/cf-deploy-prod.sh homelab duyet-homelab"
  },
  "dependencies": {
    "@duyet/components": "*",
    "@duyet/config": "*",
    "@duyet/libs": "*",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@duyet/tailwind-config": "*",
    "@duyet/tsconfig": "*",
    "@types/react": "^19.1.4",
    "typescript": "*"
  }
}
