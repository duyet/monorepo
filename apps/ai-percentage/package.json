    "cf:deploy:prod": "bun run build && bunx wrangler pages deploy dist --project-name=duyet-ai-percentage"
  },
  "dependencies": {
    "@duyet/config": "*",
    "@duyet/libs": "*",
    "@tanstack/react-router": "^1.0.0",
    "lucide-react": "^0.577.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.7.0",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@duyet/tailwind-config": "*",
    "@duyet/tsconfig": "*",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/router-plugin": "^1.0.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^6.0.0",
    "typescript": "*",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^5.0.0"
  }
}
