{
  "extends": "@duyet/tsconfig/vite.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "src",
    "components",
    "hooks",
    "lib",
    "types.d.ts",
    "vite.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "app",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "test-setup.ts",
    "test-fixtures.ts",
    "scripts"
  ]
}
