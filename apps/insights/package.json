{
  "name": "insights",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "browser": {
    "fs": false,
    "os": false,
    "path": false
  },
  "scripts": {
    "config": "bun ../../scripts/sync-app-secrets.ts duyet-insights",
    "build": "NODE_ENV=production vite build",
    "check-types": "tsc --noEmit",
    "dev": "vite dev --port 3001",
    "fmt": "bun run fix",
    "lint": "biome lint .",
    "start": "vite preview --port 3001",
    "deploy": "bun run build && bunx wrangler pages deploy dist --project-name=duyet-insights",
    "cf:deploy": "bun run --env-file=../../.env.production --env-file=../../.env.production.local build && bunx wrangler pages deploy dist --project-name=duyet-insights --commit-dirty=true",
    "cf:deploy:prod": "../../scripts/cf-deploy-prod.sh insights duyet-insights",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "@clickhouse/client": "^1.12.1",
    "@cloudflare/vite-plugin": "^1.0.0",
    "@duyet/components": "*",
    "@duyet/config": "*",
    "@duyet/libs": "*",
    "@radix-ui/react-progress": "^1.1.7",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-router": "^1.122.0",
    "@tanstack/react-start": "^1.122.0",
    "graphql-request": "^6.1.0",
    "lucide-react": "^0.577.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-is": "^19.1.0",
    "recharts": "^3.7.0",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^5.0.0",
    "vinxi": "^0.5.0"
  },
  "devDependencies": {
    "@duyet/interfaces": "*",
    "@duyet/tailwind-config": "*",
    "@duyet/tsconfig": "*",
    "@types/bun": "latest",
    "@types/react": "^19.1.4",
    "typescript": "*"
  }
}
