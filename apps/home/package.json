{
  "name": "home",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "bun test",
    "config": "bun ../../scripts/sync-app-secrets.ts duyet-home",
    "prebuild": "cd ../blog && bun scripts/generate-posts-data.ts",
    "build": "bun --bun vite build",
    "check-types": "tsc --noEmit",
    "dev": "bun --bun vite dev --port 3001",
    "fmt": "bun run fix",
    "lint": "biome lint .",
    "deploy": "bun run build && bunx wrangler pages deploy dist/client --project-name=duyet-home",
    "cf:deploy": "bun run --env-file=../../.env.production --env-file=../../.env.production.local build && bunx wrangler pages deploy dist/client --project-name=duyet-home --commit-dirty=true",
    "cf:deploy:prod": "../../scripts/cf-deploy-prod.sh home duyet-home"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.2",
    "@cloudflare/ai-search-snippet": "^0.0.39",
    "@duyet/components": "*",
    "@duyet/libs": "*",
    "@duyet/urls": "*",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-router": "^1.0.0",
    "@tanstack/react-start": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.36.0",
    "lucide-react": "^1.0.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@duyet/tailwind-config": "*",
    "@types/bun": "latest",
    "@duyet/tsconfig": "*",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^6.0.0"
  }
}
