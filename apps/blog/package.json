{
  "name": "blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "config": "bun ../../scripts/sync-app-secrets.ts duyet-blog",
    "prebuild": "bun scripts/generate-posts-data.ts && bun scripts/generate-static-files.ts",
    "build": "bun --bun vite build",
    "check-types": "tsc --noEmit",
    "dev": "bun --bun vite dev --port 3000",
    "fmt": "bun run fix",
    "lint": "biome lint .",
    "start": "bun --bun vite preview --port 3000",
    "deploy": "bun run build && bunx wrangler pages deploy dist --project-name=duyet-blog",
    "cf:deploy": "bun run --env-file=../../.env.production --env-file=../../.env.production.local build && bunx wrangler pages deploy dist --project-name=duyet-blog --commit-dirty=true",
    "cf:deploy:prod": "../../scripts/cf-deploy-prod.sh blog duyet-blog",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "@duyet/components": "*",
    "@duyet/config": "*",
    "@duyet/libs": "*",
    "@duyet/urls": "*",
    "@mdx-js/mdx": "^3.1.1",
    "@tanstack/react-router": "^1.0.0",
    "@tanstack/react-start": "^1.0.0",
    "@types/mdx": "^2.0.13",
    "katex": "^0.16.11",
    "lucide-react": "^0.577.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-highlight": "^7.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "rss": "^1.2.2",
    "sanitize-html": "^2.13.0",
    "tw-animate-css": "^1.3.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@duyet/interfaces": "*",
    "@duyet/tailwind-config": "*",
    "@duyet/tsconfig": "*",
    "@types/bun": "latest",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/router-plugin": "^1.0.0",
    "@types/react": "^19.1.4",
    "@types/rss": "^0.0.32",
    "@types/sanitize-html": "^2.16.0",
    "@vitejs/plugin-react": "^6.0.0",
    "happy-dom": "^20.8.4",
    "typescript": "*",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^5.0.0"
  }
}
