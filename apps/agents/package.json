{
  "name": "agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "browser": {
    "fs": false,
    "os": false,
    "path": false
  },
  "scripts": {
    "config": "bun ../../scripts/sync-app-secrets.ts duyet-agents",
    "prebuild": "bun run scripts/build-skills.ts",
    "build": "bun run scripts/build-skills.ts && vite build",
    "check-types": "tsc --noEmit",
    "dev": "bun run scripts/build-skills.ts && bun install http-proxy -D && node dev.js",
    "dev:vite": "bun run scripts/build-skills.ts && vite --port 3004",
    "fmt": "biome format --write .",
    "lint": "biome lint .",
    "test": "bun test",
    "test:e2e": "bun run scripts/test-e2e.ts",
    "deploy": "bun run build && bunx wrangler pages deploy out --project-name=duyet-agents",
    "cf:deploy": "bun run scripts/build-skills.ts && bun run --env-file=../../.env.production --env-file=../../.env.production.local build && bunx wrangler pages deploy out --project-name=duyet-agents --commit-dirty=true",
    "cf:deploy:prod": "../../scripts/cf-deploy-prod.sh agents duyet-agents"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.105",
    "@clerk/clerk-react": "^5.61.2",
    "@cloudflare/ai-chat": "^0.1.0",
    "@duyet/components": "*",
    "@duyet/config": "*",
    "@duyet/libs": "*",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/cjk": "^1.0.2",
    "@streamdown/code": "^1.0.3",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@xyflow/react": "^12.10.1",
    "agents": "^0.7.0",
    "ai": "^6.0.103",
    "ai-gateway-provider": "^3.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.34.3",
    "@tanstack/react-router": "^1.168.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.0",
    "streamdown": "^2.3.0",
    "tailwind-merge": "^3.4.0",
    "workers-ai-provider": "^3.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@duyet/interfaces": "*",
    "@duyet/tailwind-config": "*",
    "@duyet/tsconfig": "*",
    "@openrouter/ai-sdk-provider": "^2.2.5",
    "@tanstack/router-plugin": "^1.167.0",
    "@types/react": "^19.1.4",
    "@vitejs/plugin-react": "^4",
    "http-proxy": "^1.18.1",
    "typescript": "*",
    "vite": "6",
    "yaml": "^2.8.2",
    "@tailwindcss/vite": "^4.0.0"
  }
}
