{
  "name": "ai-percentage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "config": "bun ../../scripts/sync-app-secrets.ts duyet-ai-percentage",
    "build": "vite build",
    "check-types": "tsc --noEmit",
    "dev": "vite dev --port 3002",
    "fmt": "bun run fix",
