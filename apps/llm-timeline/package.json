{
  "name": "llm-timeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "config": "tsx ../../scripts/sync-app-secrets.ts duyet-llm-timeline",
    "build": "pnpm run prebuild && vite build && tsx ../../scripts/patch-html-for-cloudflare.ts",
    "check-types": "tsc --noEmit",
    "dev": "vite dev --port 3005",
    "fmt": "pnpm run fix",
    "lint": "biome lint .",
    "start": "vite preview --port 3005",
    "deploy": "pnpm run build && pnpm dlx wrangler pages deploy dist/client --project-name=duyet-llm-timeline",
    "cf:deploy": "dotenv -e ../../.env.production -e ../../.env.production.local -- pnpm run build && pnpm dlx wrangler pages deploy dist/client --project-name=duyet-llm-timeline --commit-dirty=true",
    "cf:deploy:prod": "../../scripts/cf-deploy-prod.sh llm-timeline duyet-llm-timeline",
    "rss": "tsx scripts/generate-rss.ts",
    "llms-txt": "tsx scripts/generate-llms-txt.ts",
    "sitemap": "tsx scripts/generate-sitemap.ts",
    "prebuild": "tsx scripts/generate-rss.ts && tsx scripts/generate-llms-txt.ts && tsx scripts/generate-data-json.ts",
    "sync": "pnpm -C \"$PWD/../..\" run rust:build && tsx scripts/sync-data.ts",
    "sync:dry": "pnpm -C \"$PWD/../..\" run rust:build && tsx scripts/sync-data.ts --dry-run --verbose"
  },
  "dependencies": {
    "@duyet/components": "*",
    "@duyet/config": "*",
    "@duyet/libs": "*",
    "@duyet/urls": "*",
    "@duyet/wasm": "*",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-router": "^1.0.0",
    "@tanstack/react-start": "^1.0.0",
    "@tanstack/react-virtual": "^3.13.22",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^1.0.0",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@duyet/tailwind-config": "*",
    "@duyet/tsconfig": "*",
    "@tailwindcss/vite": "^4.0.0",
    "@happy-dom/global-registrator": "^20.8.4",
    "@types/react": "^19.2.14",
    "happy-dom": "^20.8.4",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^6.0.0"
  }
}
