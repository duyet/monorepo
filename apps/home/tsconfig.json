{
  "extends": "@duyet/tsconfig/vite.json",
  "compilerOptions": {
    "types": ["@types/bun"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "vite-env.d.ts",
    "src",
    "index.html",
    "vite.config.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "__tests__/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
