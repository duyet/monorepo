{
  "name": "ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "check-types": "tsc --noEmit",
    "fmt": "bun run fix",
    "fix": "biome check --write .",
    "test": "vitest run",
    "preview": "opennextjs-cloudflare build && wrangler dev",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf:deploy:prod": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@duyet/components": "*",
    "@duyet/libs": "*",
    "@openai/chatkit": "^0",
    "@openai/chatkit-react": "^0",
    "next": "15.5.12",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "optionalDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "wrangler": "^4.73.0"
  },
  "devDependencies": {
    "@duyet/interfaces": "*",
    "@duyet/tailwind-config": "*",
    "@duyet/tsconfig": "*",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.0.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.12",
    "postcss": "^8.4.18",
    "tailwindcss": "^4",
    "typescript": "*",
    "happy-dom": "^20.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/jest-dom": "^6.6.0",
    "vitest": "^4.0.0"
  }
}
