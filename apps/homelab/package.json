{
  "name": "homelab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "config": "tsx ../../scripts/sync-app-secrets.ts duyet-homelab",
    "build": "vite build && tsx ../../scripts/patch-html-for-cloudflare.ts",
    "check-types": "tsc --noEmit",
    "dev": "vite dev --port 3002",
    "fmt": "pnpm run fix",
    "lint": "biome lint .",
    "start": "vite preview --port 3002",
    "test": "vitest run",
    "deploy": "pnpm run build && pnpm dlx wrangler pages deploy dist/client --project-name=duyet-homelab",
    "cf:deploy": "dotenv -e ../../.env.production -e ../../.env.production.local -- pnpm run build && pnpm dlx wrangler pages deploy dist/client --project-name=duyet-homelab --commit-dirty=true",
    "cf:deploy:prod": "../../scripts/cf-deploy-prod.sh homelab duyet-homelab"
  },
  "dependencies": {
    "@duyet/components": "*",
    "@duyet/config": "*",
    "@duyet/libs": "*",
    "@tanstack/react-router": "^1.0.0",
    "@tanstack/react-start": "^1.0.0",
    "lucide-react": "^1.0.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "recharts": "^3.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@duyet/tailwind-config": "*",
    "@duyet/tsconfig": "*",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.1.4",
    "typescript": "*",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^6.0.0"
  }
}
